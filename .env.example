# Flash Magic Terminal — sample environment configuration.
# Copy this to ~/.magic/.env  (or alongside the binary as .env)  and edit.
# All values shown are the defaults if the variable is unset.
# Per-field overrides also live in ~/.magic/config.json (managed by `rpc set` etc.)

# ─── Network ─────────────────────────────────────────────────────────────────
# mainnet-beta or devnet
MAGIC_NETWORK=mainnet-beta

# Pool name. Pool.0 on mainnet, Pool.1 on devnet.
MAGIC_POOL_NAME=Pool.0

# MagicBlock ER router URL — handles delegated state for sub-second confirms.
MAGIC_RPC_URL=https://flashtrade.magicblock.app/

# L1 (Solana) RPC for reads + L1-only ixs (deposit, withdraw, settle).
# A premium RPC (Helius / QuickNode / Triton) is strongly recommended.
MAGIC_L1_RPC_URL=https://api.mainnet-beta.solana.com

# ─── Wallet ─────────────────────────────────────────────────────────────────
# Path to a Solana CLI-format keypair JSON. Imported wallets live in ~/.flash/wallets
# and are loaded interactively at startup; this is the fallback for non-interactive use.
MAGIC_WALLET_PATH=~/.config/solana/id.json

# Auto-disconnect wallet after N ms of inactivity. 0 disables. Default 4 hours.
SESSION_TIMEOUT_MS=14400000

# ─── Trading guards ─────────────────────────────────────────────────────────
# Hard caps at the SDK level. 0 = unlimited.
MAX_COLLATERAL_PER_TRADE=0
MAX_POSITION_SIZE=0
MAX_LEVERAGE=0

# Rate limiting. Default: 10 trades/min, 1s between trades.
MAX_TRADES_PER_MINUTE=10
MIN_DELAY_BETWEEN_TRADES_MS=1000

# ─── Performance ────────────────────────────────────────────────────────────
# L1 priority fee (microlamports per CU). Higher = faster inclusion.
COMPUTE_UNIT_PRICE=50000

# Whether to skip the on-chain confirmation poll on the trade hot path.
# `true` returns sub-second; failures surface via background watcher.
MAGIC_FAST_CONFIRM=true

# ─── Logging ────────────────────────────────────────────────────────────────
# Logs land at ~/.magic/magic.log with 10MB rotation.
# Level: error | warn | info | debug
LOG_LEVEL=info
